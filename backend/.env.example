# JWT配置
JWT_SECRET=your_jwt_secret_here

# 登录配置
CLOUDSAVER_USERNAME=admin
CLOUDSAVER_PASSWORD=admin123456

# Telegram配置
TELEGRAM_BASE_URL=https://t.me/s

# Telegram频道配置
# 留空或设为 [] 时，会自动使用内置的天翼云盘频道
TELE_CHANNELS=[]

# 可选代理配置
PROXY_ENABLED=false
HTTP_PROXY_HOST=127.0.0.1
HTTP_PROXY_PORT=7890

# 影巢（HDHive）Open API，可选
HDHIVE_ENABLED=true
HDHIVE_API_KEY=
HDHIVE_TMDB_SEARCH_LIMIT=5
HDHIVE_RESOURCE_LIMIT=3
